generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int            @id @default(autoincrement())
  username       String         @unique
  email          String         @unique
  password_hash  String?
  bio            String?        @db.Text
  avatar_url     String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  is_verified    Boolean        @default(false)
  status         UserStatus     @default(active)
  firebase_uid   String         @unique
  blocksReceived Block[]        @relation("Blocked")
  blocksSent     Block[]        @relation("Blocker")
  convsAsUser1   Conversation[] @relation("User1")
  convsAsUser2   Conversation[] @relation("User2")
  followers      Follow[]       @relation("Follower")
  following      Follow[]       @relation("Following")
  likes          Like[]
  messages       Message[]
  actions        Notification[] @relation("Actor")
  notifications  Notification[] @relation("Recipient")
  posts          Post[]
  reposts        Repost[]

  @@map("users")
}

model Post {
  id            Int            @id @default(autoincrement())
  user_id       Int
  parent_id     Int?
  content       String         @db.Text
  type          PostType       @default(post)
  created_at    DateTime       @default(now())
  deleted_at    DateTime?
  updated_at    DateTime       @updatedAt
  likes         Like[]
  notifications Notification[]
  counts        PostCount?
  hashtags      PostHashtag[]
  media         PostMedia[]
  parent        Post?          @relation("Thread", fields: [parent_id], references: [id])
  replies       Post[]         @relation("Thread")
  user          User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reposts       Repost[]

  @@index([parent_id], map: "posts_parent_id_fkey")
  @@index([user_id], map: "posts_user_id_fkey")
  @@map("posts")
}

model PostMedia {
  id          Int       @id @default(autoincrement())
  post_id     Int
  media_url   String    @db.VarChar(2048)
  media_type  MediaType
  order_index Int       @default(0)
  created_at  DateTime  @default(now())
  post        Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id], map: "post_media_post_id_fkey")
  @@map("post_media")
}

model Follow {
  id           Int      @id @default(autoincrement())
  follower_id  Int
  following_id Int
  created_at   DateTime @default(now())
  follower     User     @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("Following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([following_id], map: "follows_following_id_fkey")
  @@map("follows")
}

model Block {
  id         Int      @id @default(autoincrement())
  blocker_id Int
  blocked_id Int
  created_at DateTime @default(now())
  blocked    User     @relation("Blocked", fields: [blocked_id], references: [id], onDelete: Cascade)
  blocker    User     @relation("Blocker", fields: [blocker_id], references: [id], onDelete: Cascade)

  @@unique([blocker_id, blocked_id])
  @@index([blocked_id], map: "blocks_blocked_id_fkey")
  @@map("blocks")
}

model Like {
  id         Int      @id @default(autoincrement())
  user_id    Int
  post_id    Int
  created_at DateTime @default(now())
  post       Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@index([post_id], map: "likes_post_id_fkey")
  @@map("likes")
}

model Repost {
  id            Int      @id @default(autoincrement())
  user_id       Int
  post_id       Int
  quote_content String?  @db.Text
  created_at    DateTime @default(now())
  post          Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([post_id], map: "reposts_post_id_fkey")
  @@index([user_id], map: "reposts_user_id_fkey")
  @@map("reposts")
}

model PostCount {
  post_id       Int  @id
  like_count    Int  @default(0)
  comment_count Int  @default(0)
  repost_count  Int  @default(0)
  post          Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("post_counts")
}

model Hashtag {
  id         Int           @id @default(autoincrement())
  tag_name   String        @unique
  created_at DateTime      @default(now())
  posts      PostHashtag[]

  @@map("hashtags")
}

model PostHashtag {
  post_id    Int
  hashtag_id Int
  hashtag    Hashtag @relation(fields: [hashtag_id], references: [id], onDelete: Cascade)
  post       Post    @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@id([post_id, hashtag_id])
  @@index([hashtag_id], map: "post_hashtags_hashtag_id_fkey")
  @@map("post_hashtags")
}

model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  actor_id   Int
  post_id    Int?
  type       NotificationType
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())
  actor      User             @relation("Actor", fields: [actor_id], references: [id], onDelete: Cascade)
  post       Post?            @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       User             @relation("Recipient", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([actor_id], map: "notifications_actor_id_fkey")
  @@index([post_id], map: "notifications_post_id_fkey")
  @@index([user_id], map: "notifications_user_id_fkey")
  @@map("notifications")
}

model Conversation {
  id         Int       @id @default(autoincrement())
  user1_id   Int
  user2_id   Int
  created_at DateTime  @default(now())
  user1      User      @relation("User1", fields: [user1_id], references: [id], onDelete: Cascade)
  user2      User      @relation("User2", fields: [user2_id], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([user1_id, user2_id])
  @@index([user2_id], map: "dm_conversations_user2_id_fkey")
  @@map("dm_conversations")
}

model Message {
  id              Int          @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  content         String       @db.Text
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([conversation_id], map: "messages_conversation_id_fkey")
  @@index([sender_id], map: "messages_sender_id_fkey")
  @@map("messages")
}

enum UserStatus {
  active
  banned
  deactivated
}

enum PostType {
  post
  comment
  reply
  quote
}

enum MediaType {
  image
  video
}

enum NotificationType {
  like
  reply
  follow
  repost
  mention
}
